# Build profile for the Android (Capacitor) app — used by `npm run build:apk`.
#
# The APK ships the compiled React bundle inside the device, so a relative
# "/api" would resolve against the app itself and never reach the server.
# It must be the ABSOLUTE production URL.
#
# The plain web build (`npm run build`) does NOT read this file: it keeps using
# the relative "/api" served by Vercel, exactly as before.
VITE_API_URL=https://erp-canape-client.vercel.app/api
